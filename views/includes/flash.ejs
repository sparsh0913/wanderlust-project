<!-- for success -->
 <% if(success && success.length){ %>
<div class="alert alert-success alert-dismissable fade show col-6 offset-3 mt-1 d-flex justify-content-between align-items-center" role="alert">
  <%= success %>
  <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
</div>
<% } %>


<!-- for failure -->
<% if(error && error.length){ %>
<div class="alert alert-danger alert-dismissable fade show col-6 offset-3 mt-1 d-flex justify-content-between align-items-center" role="alert">
  <%= error %>
  <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
</div>
<% } %>
